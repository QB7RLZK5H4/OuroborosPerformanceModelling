                  RowBox[{"ToString", "[", "j", "]"}], " ", "<>", 
                  " ", "\"\<)\>\""}], " ", "->", " ", 
                 RowBox[{"pSecsAcc", "[", 
                  RowBox[{"[", "j", "]"}], "]"}]}], ",", "\n", "       ", 
                RowBox[{"{", 
                 RowBox[{"j", ",", " ", "1", ",", " ", "nSections"}], "}"}]}],
                "\n", "      ", "]"}]}], "\n", "     ", "]"}], "\n", "    ", 
            "]"}]}]}], "\n", "   ", "]"}], ",", "\n", "   ", 
        RowBox[{"{", 
         RowBox[{"\[Lambda]", ",", " ", "lambdaVals"}], "}"}]}], "\n", "  ", 
       "]"}]}]}], "\n", " ", "]"}]}], "\n"}], "\n", 
 RowBox[{
